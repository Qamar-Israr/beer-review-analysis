   ],
   "source": [
    "import pandas as pd\n",
    "\n",
    "col = merged[\"beer_abv\"]\n",
    "\n",
    "Q1 = col.quantile(0.25)\n",
    "Q3 = col.quantile(0.75)\n",
    "IQR = Q3 - Q1\n",
    "\n",
    "lower = Q1 - 1.5 * IQR\n",
    "upper = Q3 + 1.5 * IQR\n",
    "\n",
    "outliers = merged[(col < lower) | (col > upper)]\n",
    "\n",
    "print(\"Number of outliers:\", len(outliers))"
   ]
  },
